{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gdictate",
  "version": "0.3.0",
  "identifier": "dev.bigidulka.gdictate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "gdictate",
        "width": 1040,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "openssl",
          "python3",
          "python3-aiohttp",
          "python3-evdev"
        ]
      },
      "rpm": {
        "depends": [
          "gtk3",
          "libappindicator-gtk3",
          "openssl",
          "python3",
          "python3-aiohttp",
          "python3-evdev",
          "webkit2gtk4.1"
        ]
      }
    },
    "resources": [
      "resources/python"
    ]
  }
}
